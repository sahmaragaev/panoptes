prometheus.scrape "windows" {
  targets = [{"__address__" = "localhost:9182"}]
  forward_to = [prometheus.remote_write.central.receiver]
  scrape_interval = "15s"
}

prometheus.remote_write "central" {
  endpoint {
    url = env("PANOPTES_SERVER_URL") + "/api/v1/write"
    headers = {
      "X-API-Key" = env("PANOPTES_API_KEY"),
    }
  }
  external_labels = {
    tenant = env("PANOPTES_TENANT"),
    hostname = env("HOSTNAME"),
  }
}

loki.source.windowsevent "application" {
  eventlog_name = "Application"
  forward_to = [loki.write.central.receiver]
}

loki.source.windowsevent "system" {
  eventlog_name = "System"
  forward_to = [loki.write.central.receiver]
}

loki.source.windowsevent "security" {
  eventlog_name = "Security"
  forward_to = [loki.write.central.receiver]
}

loki.write "central" {
  endpoint {
    url = env("PANOPTES_SERVER_URL") + "/loki/api/v1/push"
    headers = {
      "X-API-Key" = env("PANOPTES_API_KEY"),
    }
    tenant_id = env("PANOPTES_TENANT")
  }
  external_labels = {
    tenant = env("PANOPTES_TENANT"),
    hostname = env("HOSTNAME"),
  }
}
