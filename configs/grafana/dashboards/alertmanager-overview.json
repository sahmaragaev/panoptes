{
  "id": null,
  "uid": "alertmanager-overview",
  "title": "Alertmanager Overview",
  "description": "Alert management and notification monitoring dashboard",
  "tags": ["alertmanager", "alerts", "panoptes"],
  "style": "dark",
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "fiscalYearStartMonth": 0,
  "liveNow": false,
  "refresh": "10s",
  "schemaVersion": 39,
  "version": 1,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m"]
  },
  "templating": {
    "list": [
      {
        "name": "severity",
        "type": "custom",
        "label": "Severity",
        "query": "warning,critical",
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "includeAll": true,
        "multi": true,
        "options": [
          { "selected": false, "text": "warning", "value": "warning" },
          { "selected": false, "text": "critical", "value": "critical" }
        ]
      },
      {
        "name": "alertname",
        "type": "query",
        "label": "Alert Name",
        "datasource": {
          "type": "prometheus",
          "uid": null
        },
        "query": "label_values(ALERTS, alertname)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "sort": 1
      }
    ]
  },
  "annotations": {
    "list": []
  },
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Currently Firing Alerts",
      "type": "table",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 },
      "datasource": {
        "type": "prometheus",
        "uid": null
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": null
          },
          "expr": "ALERTS{alertstate=\"firing\", severity=~\"$severity\", alertname=~\"$alertname\"}",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "color-text"
            },
            "filterable": true,
            "inspect": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#73BF69", "value": null }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "severity"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background",
                  "mode": "basic"
                }
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "warning": {
                        "color": "#FADE2A",
                        "index": 0,
                        "text": "WARNING"
                      },
                      "critical": {
                        "color": "#F2495C",
                        "index": 1,
                        "text": "CRITICAL"
                      }
                    }
                  }
                ]
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "alertstate"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background",
                  "mode": "basic"
                }
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "firing": {
                        "color": "#F2495C",
                        "index": 0,
                        "text": "FIRING"
                      }
                    }
                  }
                ]
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": true,
          "reducer": ["count"],
          "countRows": true
        },
        "sortBy": [
          {
            "desc": true,
            "displayName": "severity"
          }
        ]
      }
    },
    {
      "id": 2,
      "title": "Alert History Timeline",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 10 },
      "datasource": {
        "type": "prometheus",
        "uid": null
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": null
          },
          "expr": "sum(ALERTS{alertstate=\"firing\"})",
          "legendFormat": "Firing"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": null
          },
          "expr": "sum(ALERTS{alertstate=\"pending\"})",
          "legendFormat": "Pending"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "Active Alerts",
            "drawStyle": "line",
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": {
              "group": "A",
              "mode": "none"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#73BF69", "value": null },
              { "color": "#FADE2A", "value": 5 },
              { "color": "#F2495C", "value": 20 }
            ]
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Firing"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#F2495C",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Pending"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#FADE2A",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "calcs": ["mean", "max", "sum"],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 3,
      "title": "Notification Success / Failure Rates",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "datasource": {
        "type": "prometheus",
        "uid": null
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": null
          },
          "expr": "rate(alertmanager_notifications_total{integration=\"webhook\"}[$__rate_interval])",
          "legendFormat": "Total"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": null
          },
          "expr": "rate(alertmanager_notifications_failed_total{integration=\"webhook\"}[$__rate_interval])",
          "legendFormat": "Failed"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "Notifications / sec",
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": {
              "group": "A",
              "mode": "none"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#73BF69", "value": null }
            ]
          },
          "unit": "ops"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": "/Failed.*/"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#F2495C",
                  "mode": "fixed"
                }
              },
              {
                "id": "custom.fillOpacity",
                "value": 25
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": "/Total.*/"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#73BF69",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "calcs": ["mean", "sum"],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 4,
      "title": "Alert Group Summary",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "datasource": {
        "type": "prometheus",
        "uid": null
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": null
          },
          "expr": "count by (alertname, severity) (ALERTS{alertstate=\"firing\", severity=~\"$severity\"})",
          "format": "table",
          "instant": true,
          "legendFormat": "{{alertname}} ({{severity}})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#73BF69", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "values": ["value", "percent"]
        },
        "pieType": "donut",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      }
    },
    {
      "id": 5,
      "title": "Active Silences",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 26 },
      "datasource": {
        "type": "prometheus",
        "uid": null
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": null
          },
          "expr": "alertmanager_silences{state=\"active\"}",
          "instant": true,
          "legendFormat": "Active Silences"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#73BF69", "value": null },
              { "color": "#FADE2A", "value": 5 },
              { "color": "#F2495C", "value": 15 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 6,
      "title": "Pending Silences",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 26 },
      "datasource": {
        "type": "prometheus",
        "uid": null
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": null
          },
          "expr": "alertmanager_silences{state=\"pending\"}",
          "instant": true,
          "legendFormat": "Pending Silences"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#5794F2", "value": null },
              { "color": "#FADE2A", "value": 3 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 7,
      "title": "Expired Silences",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 26 },
      "datasource": {
        "type": "prometheus",
        "uid": null
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": null
          },
          "expr": "alertmanager_silences{state=\"expired\"}",
          "instant": true,
          "legendFormat": "Expired Silences"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#5794F2", "value": null }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 8,
      "title": "Total Firing Alerts",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 26 },
      "datasource": {
        "type": "prometheus",
        "uid": null
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": null
          },
          "expr": "count(ALERTS{alertstate=\"firing\"})",
          "instant": true,
          "legendFormat": "Firing"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#73BF69", "value": null },
              { "color": "#FADE2A", "value": 3 },
              { "color": "#F2495C", "value": 10 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    }
  ]
}