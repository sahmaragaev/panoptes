      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            {
              "options": {
                "0": { "color": "#F2495C", "index": 1, "text": "STOPPED" },
                "1": { "color": "#73BF69", "index": 0, "text": "RUNNING" }
              },
              "type": "value"
