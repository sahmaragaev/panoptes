      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 16,
      "title": "Network",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 38 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 17,
      "title": "Network Bandwidth Per Interface",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 39 },
      "datasource": { "type": "prometheus", "uid": null },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(node_network_receive_bytes_total{instance=~\"$node\",device!~\"lo|veth.*|docker.*|br.*\"}[5m])",
          "legendFormat": "{{device}} rx",
          "instant": false
        },
        {
          "refId": "B",
          "expr": "-rate(node_network_transmit_bytes_total{instance=~\"$node\",device!~\"lo|veth.*|docker.*|br.*\"}[5m])",
          "legendFormat": "{{device}} tx",
          "instant": false
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": true,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 15,
