{
  "id": null,
  "uid": "loki-logs",
  "title": "Log Explorer",
  "description": "Log exploration dashboard powered by Loki",
  "tags": ["loki", "logs", "panoptes"],
  "style": "dark",
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "fiscalYearStartMonth": 0,
  "liveNow": false,
  "refresh": "5s",
  "schemaVersion": 39,
  "version": 1,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m"]
  },
  "templating": {
    "list": [
      {
        "name": "job",
        "type": "query",
        "label": "Job",
        "datasource": {
          "type": "loki",
          "uid": null
        },
        "query": "label_values({job=~\".+\"}, job)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "sort": 1
      },
      {
        "name": "hostname",
        "type": "query",
        "label": "Hostname",
        "datasource": {
          "type": "loki",
          "uid": null
        },
        "query": "label_values({job=~\".+\"}, hostname)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "sort": 1
      },
      {
        "name": "tenant",
        "type": "query",
        "label": "Tenant",
        "datasource": {
          "type": "loki",
          "uid": null
        },
        "query": "label_values({job=~\".+\"}, tenant)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "sort": 1
      },
      {
        "name": "search",
        "type": "textbox",
        "label": "Search",
        "current": {
          "selected": false,
          "text": "",
          "value": ""
        }
      },
      {
        "name": "level",
        "type": "custom",
        "label": "Level",
        "query": "info,warn,error,debug",
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "includeAll": true,
        "multi": true,
        "options": [
          { "selected": false, "text": "info", "value": "info" },
          { "selected": false, "text": "warn", "value": "warn" },
          { "selected": false, "text": "error", "value": "error" },
          { "selected": false, "text": "debug", "value": "debug" }
        ]
      }
    ]
  },
  "annotations": {
    "list": []
  },
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Log Volume Over Time",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "datasource": {
        "type": "loki",
        "uid": null
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": null
          },
          "expr": "sum by(job) (count_over_time({job=~\"$job\",hostname=~\"$hostname\",tenant=~\"$tenant\"}[$__interval]))",
          "legendFormat": "{{job}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "Log Count",
            "fillOpacity": 80,
            "gradientMode": "none",
            "lineWidth": 1,
            "stacking": {
              "group": "A",
              "mode": "normal"
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#73BF69", "value": null },
              { "color": "#FADE2A", "value": 1000 },
              { "color": "#F2495C", "value": 5000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "barRadius": 0.1,
        "barWidth": 0.9,
        "groupWidth": 0.7,
        "legend": {
          "calcs": [],
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "orientation": "auto",
        "showValue": "never",
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "xTickLabelRotation": 0
      }
    },
    {
      "id": 2,
      "title": "Live Log Stream",
      "type": "logs",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 8 },
      "datasource": {
        "type": "loki",
        "uid": null
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": null
          },
          "expr": "{job=~\"$job\",hostname=~\"$hostname\",tenant=~\"$tenant\"} |~ \"$search\" |~ \"$level\"",
          "maxLines": 500
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {}
        },
        "overrides": []
      },
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
    {
      "id": 3,
      "title": "Top Error Patterns",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": {
        "type": "loki",
        "uid": null
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": null
          },
          "expr": "topk(10, sum by(job, level) (count_over_time({job=~\"$job\",hostname=~\"$hostname\",tenant=~\"$tenant\"} |= \"error\" [$__interval])))",
          "legendFormat": "{{job}} - {{level}}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "color-text"
            },
            "filterable": true,
            "inspect": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#73BF69", "value": null },
              { "color": "#FADE2A", "value": 10 },
              { "color": "#F2495C", "value": 50 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false,
          "reducer": ["sum"]
        },
        "sortBy": [
          {
            "desc": true,
            "displayName": "Value"
          }
        ]
      }
    },
    {
      "id": 4,
      "title": "SSH Failed Login Attempts Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": {
        "type": "loki",
        "uid": null
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": null
          },
          "expr": "count_over_time({job=\"auth\"} |= \"Failed password\" | pattern `<_> Failed password for <user> from <ip>` [5m])",
          "legendFormat": "Failed SSH Logins"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "#F2495C",
            "mode": "fixed"
          },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "Attempts",
            "drawStyle": "line",
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": {
              "group": "A",
              "mode": "none"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#73BF69", "value": null },
              { "color": "#FADE2A", "value": 5 },
              { "color": "#F2495C", "value": 20 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": ["mean", "max"],
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      }
    },
    {
      "id": 5,
      "title": "Docker Container Error Log Rates",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 28 },
      "datasource": {
        "type": "loki",
        "uid": null
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": null
          },
          "expr": "sum by (container) (count_over_time({job=\"docker\"} |= \"error\" [5m]))",
          "legendFormat": "{{container}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "Errors / 5m",
            "drawStyle": "bars",
            "fillOpacity": 50,
            "gradientMode": "scheme",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": {
              "group": "A",
              "mode": "normal"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#73BF69", "value": null },
              { "color": "#FADE2A", "value": 10 },
              { "color": "#F2495C", "value": 50 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": ["sum"],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    }
  ]
}